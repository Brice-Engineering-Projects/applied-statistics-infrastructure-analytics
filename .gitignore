# uv
.venv/
.venv*/
uv.lock

# pip / venv
venv/
env/
ENV/
env.bak/
venv.bak/

# conda
.conda/
conda-meta/
*.conda

# poetry
# poetry.lock is intentionally NOT ignored — it should be committed for reproducibility

# pipenv
# Pipfile.lock is intentionally NOT ignored — commit it for reproducibility

